@model MvcCoreCosmosDb.Models.Coche

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Coche</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            Id
        </dt>
        <dd class = "col-sm-10">
            @Model.Id
        </dd>
        <dt class = "col-sm-2">
            Marca
        </dt>
        <dd class = "col-sm-10">
            @Model.Marca
        </dd>
        <dt class = "col-sm-2">
            Modelo
        </dt>
        <dd class = "col-sm-10">
            @Model.Modelo
        </dd>

        @if(Model.Motor != null)
        {
            <dt class = "col-sm-2">
                Motor
            </dt>
            <dd class = "col-sm-10">
                Tipo: @Model.Motor.Tipo <br />
                Caballos: @Model.Motor.Caballos <br />
                Turbo: @Model.Motor.Turbo
            </dd>
        }

        <dt class = "col-sm-2">
            Imagen
        </dt>
        <dd class="col-sm-10">
            <img src="@Model.Imagen" alt="Imagen de @Model.Marca @Model.Modelo" class="img-fluid" style="width:250px" />
            <a href="@Model.Imagen" target="_blank">@Model.Imagen</a>
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a> |
    <a asp-action="MisCoches">Back to List</a>
</div>
